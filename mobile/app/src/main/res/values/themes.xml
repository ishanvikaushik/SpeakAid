<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.Speakaid" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/duo_blue</item>
        <item name="colorPrimaryShadow">@color/duo_blue_shadow</item>
        <item name="colorSecondary">@color/duo_green</item>
        <item name="colorSecondaryShadow">@color/duo_green_shadow</item>
        <item name="android:windowBackground">@color/background_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="textAppearanceHeadlineLarge">@style/HeadlineLarge</item>
        <item name="textAppearanceBodyLarge">@style/BodyLarge</item>
        <item name="themeBackground">@drawable/theme_background_gradient</item>
    </style>

    <style name="Theme.Speakaid" parent="Base.Theme.Speakaid">
        <item name="themeBackground">@android:color/white</item>
    </style>

    <style name="Theme.Speakaid.Dashboard" parent="Theme.Speakaid">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>

    <style name="Theme.Speakaid.Lavender" parent="Base.Theme.Speakaid">
        <item name="colorPrimary">#D1C4E9</item>
        <item name="colorSecondary">#E1BEE7</item>
        <item name="themeBackground">@drawable/theme_background_gradient</item>
    </style>

    <style name="Theme.Speakaid.Ocean" parent="Base.Theme.Speakaid">
        <item name="colorPrimary">#B3E5FC</item>
        <item name="colorSecondary">#81D4FA</item>
        <item name="themeBackground">@drawable/theme_background_gradient</item>
    </style>

    <style name="Theme.Speakaid.Sunset" parent="Base.Theme.Speakaid">
        <item name="colorPrimary">#FFCC80</item> <!-- Soft Orange -->
        <item name="colorSecondary">#FFF59D</item> <!-- Soft Yellow -->
        <item name="themeBackground">@drawable/theme_background_gradient</item>
    </style>

    <style name="HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_main</item>
    </style>

    <style name="BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.Speakaid.Progress" parent="Widget.Material3.LinearProgressIndicator">
        <item name="indicatorColor">?attr/colorPrimary</item>
        <item name="trackColor">@color/border_gray</item>
    </style>
</resources>
