<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create Custom Phrase"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/editCustomPhrase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter sentence to be spoken"
        android:inputType="textCapSentences"
        android:padding="12dp"
        android:background="@drawable/duo_card_white"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose an Icon"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="24dp">
        
        <RadioGroup
            android:id="@+id/rgIconPicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <RadioButton android:id="@+id/rbIconYes" android:layout_width="60dp" android:layout_height="60dp" android:button="@null" android:background="@drawable/ic_yes" android:layout_margin="8dp"/>
            <RadioButton android:id="@+id/rbIconHappy" android:layout_width="60dp" android:layout_height="60dp" android:button="@null" android:background="@drawable/ic_happy" android:layout_margin="8dp" android:checked="true"/>
            <RadioButton android:id="@+id/rbIconHelp" android:layout_width="60dp" android:layout_height="60dp" android:button="@null" android:background="@drawable/ic_help" android:layout_margin="8dp"/>
            <RadioButton android:id="@+id/rbIconFood" android:layout_width="60dp" android:layout_height="60dp" android:button="@null" android:background="@drawable/ic_food" android:layout_margin="8dp"/>
            <RadioButton android:id="@+id/rbIconWater" android:layout_width="60dp" android:layout_height="60dp" android:button="@null" android:background="@drawable/ic_water" android:layout_margin="8dp"/>
            <RadioButton android:id="@+id/rbIconToilet" android:layout_width="60dp" android:layout_height="60dp" android:button="@null" android:background="@drawable/ic_toilet" android:layout_margin="8dp"/>
            <RadioButton android:id="@+id/rbIconTired" android:layout_width="60dp" android:layout_height="60dp" android:button="@null" android:background="@drawable/ic_tired" android:layout_margin="8dp"/>
            <RadioButton android:id="@+id/rbIconChat" android:layout_width="60dp" android:layout_height="60dp" android:button="@null" android:background="@drawable/ic_chat" android:layout_margin="8dp"/>
            
        </RadioGroup>
    </HorizontalScrollView>

</LinearLayout>
