<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- 1. FULL PAGE BACKGROUND IMAGE -->
    <ImageView
        android:id="@+id/imgDashboardBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 2. LIGHT OVERLAY -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#15000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="60dp">

            <!-- 3. CLOUD QUOTE BUBBLE -->
            <RelativeLayout
                android:id="@+id/quoteContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="50dp">

                <ImageView
                    android:id="@+id/imgCloud"
                    android:layout_width="320dp"
                    android:layout_height="180dp"
                    android:src="@drawable/cloud"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/txtQuote"
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="&quot;Every progress, no matter how small, is a victory.&quot;"
                    android:textSize="18sp"
                    android:textColor="#455A64"
                    android:gravity="center"
                    android:paddingBottom="20dp"
                    android:fontFamily="sans-serif-medium" />
            </RelativeLayout>

            <!-- 4. SEPARATE PANDA MASCOT -->
            <ImageView
                android:id="@+id/imgMascot"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:src="@drawable/panda"
                app:layout_constraintTop_toBottomOf="@id/quoteContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="-20dp" />

            <!-- 5. APP TITLE -->
            <TextView
                android:id="@+id/appTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SpeakAid"
                android:textSize="48sp"
                android:textColor="#2C3E50"
                android:fontFamily="sans-serif-black"
                app:layout_constraintTop_toBottomOf="@id/imgMascot"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- 6. ACTION BUTTONS -->
            <LinearLayout
                android:id="@+id/buttonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/appTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="40dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUser"
                    android:layout_width="280dp"
                    android:layout_height="72dp"
                    android:text="USER MODE"
                    android:textSize="18sp"
                    app:cornerRadius="36dp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="16dp"
                    android:elevation="6dp"
                    app:backgroundTint="#B39DDB" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCaregiver"
                    android:layout_width="280dp"
                    android:layout_height="72dp"
                    android:text="CAREGIVER MODE"
                    android:textSize="18sp"
                    app:cornerRadius="36dp"
                    android:fontFamily="sans-serif-black"
                    android:elevation="6dp"
                    app:backgroundTint="#4FC3F7" />

            </LinearLayout>

            <!-- 7. FOOTER (GLASS EFFECT) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/footerCard"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#B3FFFFFF"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="1.5dp"
                app:layout_constraintTop_toBottomOf="@id/buttonContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="60dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="I'm here for you 💜"
                        android:textColor="#546E7A"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
