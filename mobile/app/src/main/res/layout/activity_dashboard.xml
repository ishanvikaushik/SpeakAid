<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/glowing_foggy_background"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="60dp">

            <RelativeLayout
                android:id="@+id/quoteContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="50dp">

                <ImageView
                    android:id="@+id/imgCloud"
                    android:layout_width="320dp"
                    android:layout_height="180dp"
                    android:src="@drawable/cloud"
                    android:scaleType="fitXY" />

                <TextView
                    android:id="@+id/txtQuote"
                    android:layout_width="240dp"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="&quot;Every progress, no matter how small, is a victory.&quot;"
                    android:textSize="18sp"
                    android:textColor="#455A64"
                    android:gravity="center"
                    android:paddingBottom="20dp"
                    android:fontFamily="sans-serif-medium" />
            </RelativeLayout>

            <ImageView
                android:id="@+id/imgMascot"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:src="@drawable/panda"
                app:layout_constraintTop_toBottomOf="@id/quoteContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="-20dp" />

            <TextView
                android:id="@+id/appTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SpeakAid"
                android:textSize="52sp"
                android:textColor="#2C3E50"
                android:fontFamily="sans-serif-black"
                app:layout_constraintTop_toBottomOf="@id/imgMascot"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="8dp" />

            <!-- ACTION BUTTONS: AESTHETIC GRADIENT -->
            <LinearLayout
                android:id="@+id/buttonContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/appTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="40dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUser"
                    android:layout_width="280dp"
                    android:layout_height="80dp"
                    android:text="USER MODE"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="20dp"
                    android:elevation="8dp"
                    app:backgroundTint="@null"
                    android:background="@drawable/aesthetic_gradient_user" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCaregiver"
                    android:layout_width="280dp"
                    android:layout_height="80dp"
                    android:text="CAREGIVER MODE"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black"
                    android:elevation="8dp"
                    app:backgroundTint="@null"
                    android:background="@drawable/aesthetic_gradient_caregiver" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/footerCard"
                android:layout_width="320dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFF0F5"
                app:strokeColor="#FFBDEB"
                app:strokeWidth="3dp"
                app:layout_constraintTop_toBottomOf="@id/buttonContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="50dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_heart"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="I am here for you"
                        android:textColor="#E91E63"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(づ｡◕‿‿◕｡)づ"
                        android:textColor="#E91E63"
                        android:textSize="24sp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
