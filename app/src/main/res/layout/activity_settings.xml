<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Accessibility"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <Switch
        android:id="@+id/switchSound"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sound (Text-to-Speech)"
        android:textSize="18sp"
        android:padding="8dp"
        android:layout_marginBottom="8dp"/>

    <Switch
        android:id="@+id/switchVibration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vibration"
        android:textSize="18sp"
        android:padding="8dp"
        android:layout_marginBottom="8dp"/>

    <Switch
        android:id="@+id/switchMotion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reduce Motion (Skip Countdowns)"
        android:textSize="18sp"
        android:padding="8dp"
        android:layout_marginBottom="24dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Caregiver Settings"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnChangePasscode"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Change Caregiver Passcode"
        android:textSize="16sp"
        android:backgroundTint="#607D8B"/>

</LinearLayout>
